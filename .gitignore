# =========================================================================
# 华南森孚贸易有限公司 - Git Ignore 配置文件
# =========================================================================
# 文件说明：配置 Git 版本控制中需要忽略的文件和目录
# 位置：网站根目录（.gitignore）
# 更新时间：2026-03-06
# 
# 语法规则：
#   # - 注释行，用于说明
#   * - 通配符，匹配任意字符
#   ? - 通配符，匹配单个字符
#   ** - 匹配多级目录
#   ! - 否定，表示不忽略
# =========================================================================

# =========================================================================
# 一、操作系统文件（必须忽略）
# =========================================================================

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows 系统文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
@eaDir/

# Linux 系统文件
.directory
.cache/

# 编辑器临时文件
*~
*.swp
*.swo
\#*\#

# =========================================================================
# 二、代码编辑器和 IDE 文件（建议忽略）
# =========================================================================

# VS Code（Visual Studio Code）
.vscode/
*.code-workspace
.history/

# Lingma
.lingma/

# =========================================================================
# 十一、特定于本项目的忽略规则
# =========================================================================

# AI 优化文档（如果不需要公开）
DOMESTIC_AI_OPTIMIZATION.md
AI_OPTIMIZATION_GUIDE.md
AI_DEPLOYMENT_CHECKLIST.md
README_AI_OPTIMIZATION.md
README_AI_OPTIMIZATION_ENHANCED.md

# SEO 文档（如果不需要公开）
SEO_GUIDE.md

# =========================================================================
# 十二、其他常见忽略项
# =========================================================================

# Release 配置
.releaserc
.release.json

# Changelog（自动生成）
CHANGELOG.md
HISTORY.md

# =========================================================================
# 十三、不忽略的重要文件（例外规则）
# =========================================================================

# 不要忽略重要的配置文件
!config.json
!config.example.json
!package.json
!tsconfig.json
!jsconfig.json

# 不要忽略 README（但文档可以忽略）
!README.md

# 不要忽略入口文件
!index.html
!main.js
!app.js
!main.css
!style.css

# 不要忽略必要的 CSS 文件
!css/style.css
!css/images.css
!css/mobile.css

# 不要忽略必要的 JS 文件
!js/main.js

# 不要忽略 HTML 文件
!*.html

# 不要忽略 AI 优化核心文件（建议保留）
!robots.txt
!sitemap.xml
!llms.txt

# =========================================================================
# 十四、特殊规则说明
# =========================================================================

# 忽略所有 .txt 文件，但保留 llms.txt
*.txt
!llms.txt
!robots.txt

# 忽略所有 .md 文件，但保留 README.md
*.md
!README.md
!README_AI_OPTIMIZATION_ENHANCED.md

# 忽略所有 JSON 文件，但保留示例配置
*.json
!package.json
!*.example.json

# =========================================================================
# 使用说明
# =========================================================================
# 1. 将此文件保存为 .gitignore（注意前面的点）
# 2. 放置在项目根目录
# 3. Git 会自动忽略列出的文件和目录
# 4. 如需修改，编辑此文件即可
# 5. 已跟踪的文件不会被忽略，需要使用 git rm --cached <file> 移除跟踪

# 验证命令：
# git check-ignore -v <filename>  # 检查某个文件为何被忽略
# git status                      # 查看当前状态，确认忽略生效

# =========================================================================
# 最佳实践建议
# =========================================================================
# 1. 只提交源代码和必要配置
# 2. 不提交编译产物和依赖包
# 3. 不提交敏感信息和密钥
# 4. 不提交大型二进制文件（使用 Git LFS）
# 5. 定期清理无用的临时文件
# 6. 团队协作前统一 .gitignore 配置
# =========================================================================
